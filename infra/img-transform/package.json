{
  "name": "yaksha-img-transform",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud Run image-transformation service. Sits behind Cloud CDN, reads images from GCS, applies Sharp transforms on cache miss, returns webp/avif/jpeg based on Accept header.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "express": "^4.21.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}