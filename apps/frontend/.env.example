# ═══════════════════════════════════════════════════════════════════════════════
#  YAKSHA FAQ PORTAL — Frontend Environment Variables
#  Copy this file to .env and fill in values.
#
#  In a single-container deployment (backend serves frontend), these are
#  baked into the Vite build at docker image build time.
#  For local dev, the Vite proxy in vite.config.ts forwards /csfaq/api to :6767.
# ═══════════════════════════════════════════════════════════════════════════════

# Backend API URL (no trailing slash)
# In single-container mode, leave EMPTY so it defaults to /csfaq/api (same origin).
# Only set this if frontend is deployed separately (e.g. Vercel → external API).
VITE_API_URL=

# Frontend public URL (used by admin to link back to the user-facing site)
# Leave unset in local dev — code falls back to window.location.origin
VITE_PUBLIC_URL=
