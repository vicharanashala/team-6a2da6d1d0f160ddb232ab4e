# ═══════════════════════════════════════════════════════════════════════════════
#  YAKSHA FAQ PORTAL — Backend Environment Variables
#  Copy to .env and fill in every value.
#  Values set to =# mean "unconfigured — fill before use".
#  Server will NOT start without MONGODB_URI and JWT_SECRET at minimum.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core Server ────────────────────────────────────────────────────────────────
PORT=6767
NODE_ENV=development
CLIENT_URL=#

# ── MongoDB ────────────────────────────────────────────────────────────────────
# https://cloud.mongodb.com → Cluster → Connect → Connection String
MONGODB_URI=#

# ── JWT & Session Authentication ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=#
# Optional: dedicated refresh token secret (defaults to JWT_SECRET)
JWT_REFRESH_SECRET=#
# Optional: access token TTL (e.g. 15m, 1h, 7d — defaults to config.yaml)
JWT_EXPIRES_IN=7d

# ── Encryption & OAuth Secrets ─────────────────────────────────────────────────
# Dedicated AES-GCM key for encrypting Zoom tokens, TOTP etc.
# Generate with: openssl rand -hex 32
# Falls back to JWT_SECRET if unset.
ENCRYPTION_MASTER_KEY=#
# Dedicated HMAC secret for OAuth state signing.
# Generate with: openssl rand -hex 32
# Falls back to JWT_SECRET if unset.
OAUTH_STATE_SECRET=#

# ── Redis ──────────────────────────────────────────────────────────────────────
# Upstash REST endpoint (optional — enables cross-instance cache)
REDIS_URL=#
REDIS_TOKEN=#
# BullMQ TCP URL (required for OCR & document queue worker)
REDIS_TCP_URL=#

# ── Sentry (optional — error tracking) ────────────────────────────────────────
# https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=#

# ═══════════════════════════════════════════════════════════════════════════════
#  EMBEDDING PROVIDERS
#  Used by the semantic search & duplicate detection pipelines.
#  Priority: Database AiConfig → env vars → local ONNX fallback.
# ═══════════════════════════════════════════════════════════════════════════════

# HuggingFace Inference API (recommended for production — no 1.2GB ONNX download)
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=#

# Generic embedding API key & base URL (used by OpenAI or OpenAI-compatible embedding providers like vLLM/Ollama)
# For official OpenAI, set EMBEDDING_API_KEY to your OpenAI key and EMBEDDING_BASE_URL to https://api.openai.com/v1
# For local or custom self-hosted engines (e.g. Ollama, vLLM), set base URL and keys accordingly.
EMBEDDING_API_KEY=#
EMBEDDING_BASE_URL=#

# Embedding model overrides (fallback when database config is not set)
# Supported providers: local | huggingface | openai | custom
# Default provider: local (or huggingface if HUGGINGFACE_API_KEY is present)
# Default model: mixedbread-ai/mxbai-embed-large-v1
# Default dimensions: 1024
EMBEDDING_PROVIDER=#
EMBEDDING_MODEL=#
EMBEDDING_DIMENSIONS=#

# ═══════════════════════════════════════════════════════════════════════════════
#  AI CHAT PROVIDERS — duplicate detection, auto-answer, FAQ audit
#  At least ONE must be set. Server refuses to start without one.
#  Priority (first configured key wins): Anthropic → OpenAI → Grok → Gemini → MiniMax → Custom
# ═══════════════════════════════════════════════════════════════════════════════

# ANTHROPIC CLAUDE (recommended)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=#
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=#

# OPENAI GPT
# https://platform.openai.com/api-keys
OPENAI_API_KEY=#
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=#

# XAI GROK
# https://console.x.ai/
XAI_API_KEY=#
XAI_MODEL=grok-3
XAI_BASE_URL=#

# GOOGLE GEMINI
# https://aistudio.google.com/
GEMINI_API_KEY=#
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=#

# MINIMAX TEXT
# https://platform.minimax.io → Token Plan → API Key
MINIMAX_API_KEY=#
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.io/v1

# CUSTOM PROVIDER (vLLM, Ollama, etc.)
CUSTOM_API_KEY=#
CUSTOM_MODEL=#
CUSTOM_BASE_URL=http://localhost:11434/v1

# ALTERNATIVE AI KEYS (fallback extraction / welcome package generation)
GROK_API_KEY=#
GROQ_API_KEY=#

# ── Per-Pipeline AI Overrides ──────────────────────────────────────────────────
# Providers: anthropic | openai | xai | minimax | gemini | custom
FAQ_AUDIT_PROVIDER=#
FAQ_AUDIT_MODEL=#
AUTO_ANSWER_PROVIDER=#
AUTO_ANSWER_MODEL=#

# ── Unanswered Question Escalation ────────────────────────────────────────────
UNANSWERED_ESCALATION_DAYS=7
UNANSWERED_ESCALATION_CHECK_MINUTES=60

# ═══════════════════════════════════════════════════════════════════════════════
#  ZOOM OAUTH & WEBHOOKS
#  https://marketplace.zoom.us → Create User-managed OAuth app
#  Required scopes: recording:read, meeting:read:admin
# ═══════════════════════════════════════════════════════════════════════════════
ZOOM_CLIENT_ID=#
ZOOM_CLIENT_SECRET=#
# Must match exactly what's in your Zoom App redirect URL settings
ZOOM_REDIRECT_URI=#
# Comma-separated regexes — matching meeting topics are skipped
ZOOM_TOPIC_BLACKLIST=#
# Required in production for verifying webhook payloads
ZOOM_WEBHOOK_SECRET_TOKEN=#

# ═══════════════════════════════════════════════════════════════════════════════
#  IMAGE STORAGE
# ═══════════════════════════════════════════════════════════════════════════════

# Cloudinary (LEGACY — being phased out in favor of GCS)
# https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=#
CLOUDINARY_API_KEY=#
CLOUDINARY_API_SECRET=#
CLOUDINARY_FOLDER=yaksha

# Google Cloud Storage (NEW — primary image storage)
# In production on Cloud Run: instance service account is used implicitly.
# For local dev: set GOOGLE_APPLICATION_CREDENTIALS or run `gcloud auth application-default login`.
GCS_BUCKET=#
GCS_PUBLIC_HOST=#
GCS_ALLOWED_SUBFOLDERS=avatar,posts
# Path to GCP service account key JSON (local dev only — NOT needed in Cloud Run)
GOOGLE_APPLICATION_CREDENTIALS=#

# ═══════════════════════════════════════════════════════════════════════════════
#  DISCORD BOT & ADMIN
#  https://discord.com/developers/applications
# ═══════════════════════════════════════════════════════════════════════════════
DISCORD_BOT_TOKEN=#
DISCORD_CLIENT_ID=#
DISCORD_GUILD_ID=#
DISCORD_ADMIN_USER_IDS=#
DISCORD_NOTIFICATION_CHANNEL_ID=#
DISCORD_PUBLIC_CHANNEL_ID=#
INTERNAL_API_KEY=#

# Public URL used for invite links and API references
PUBLIC_URL=#
# Public base URL for controlled registration invite links
PUBLIC_BASE_URL=#

# Channel ID for logging admin audit events
ADMIN_DISCORD_LOG_CHANNEL=#

# Logging webhook URL (sends ALERT/ERROR level events to Discord)
DISCORD_WEBHOOK_URL=#

# Passphrase to change backend config via Discord Admin commands
# Fallback: "adminpassphrase" in development. REQUIRED in production.
DISCORD_ADMIN_PASSPHRASE=#
ADMIN_DISCORD_PASSPHRASE=#

# Override bcrypt cost factor for admin passphrase hashing (Default: 12)
ADMIN_BCRYPT_COST=12

# ═══════════════════════════════════════════════════════════════════════════════
#  DOCUMENT & KNOWLEDGE PIPELINE
# ═══════════════════════════════════════════════════════════════════════════════
# Search count threshold to auto-promote a document insight to FAQ
DOCUMENT_INSIGHT_AUTO_PROMOTE_THRESHOLD=3

# ═══════════════════════════════════════════════════════════════════════════════
#  INFISICAL (production secret injection via Docker)
#  Only needed on the VPS / in docker-compose.prod.yml.
#  NOT needed for local development.
# ═══════════════════════════════════════════════════════════════════════════════
INFISICAL_TOKEN=#
INFISICAL_ENVIRONMENT=#
INFISICAL_PROJECT_ID=#
INFISICAL_SECRET_PATH=#

# ═══════════════════════════════════════════════════════════════════════════════
#  DOCKER HUB (CI/CD — set as GitHub Secrets, not here)
# ═══════════════════════════════════════════════════════════════════════════════
DOCKERHUB_USERNAME=#
DOCKERHUB_TOKEN=#

# ═══════════════════════════════════════════════════════════════════════════════
#  VPS DEPLOYMENT (CI/CD — set as GitHub Secrets, not here)
# ═══════════════════════════════════════════════════════════════════════════════
# Staging
STAGING_SSH_HOST=#
STAGING_SSH_USER=#
STAGING_SSH_KEY=#
# Production
PROD_SSH_HOST=#
PROD_SSH_USER=#
PROD_SSH_KEY=#

# ── Local Development Tunnels (run.sh only) ────────────────────────────────────
# ngrok auth token to expose local port 6767 to the internet
NGROK_AUTH_TOKEN=#
