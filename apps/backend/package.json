{
  "name": "yaksha-faq-backend",
  "version": "0.1.0",
  "description": "Yaksha FAQ Portal - Backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "migrate": "tsx src/scripts/addIndexes.ts",
    "create:vector-index": "tsx src/scripts/createVectorIndex.ts",
    "seed": "tsx src/scripts/seed.ts",
    "seed:posts": "tsx src/scripts/seedPosts.ts",
    "backfill:embeddings": "tsx src/scripts/backfillEmbeddings.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "seed:search-logs": "tsx src/scripts/seedSearchLogs.ts",
    "seed:badges": "tsx src/scripts/seedBadges.ts",
    "add:post": "tsx src/scripts/addPost.ts",
    "backfill:community": "tsx src/scripts/backfillCommunityEmbeddings.ts",
    "backfill:public-metrics": "tsx src/scripts/backfillPublicMetrics.ts",
    "audit:data": "tsx src/scripts/auditData.ts",
    "cleanup:orphan-notifications": "tsx src/scripts/cleanupOrphanNotifications.ts",
    "seed:live": "tsx src/scripts/seedLiveData.ts",
    "fetch:faqs": "tsx src/scripts/fetchFaqsFromSite.ts",
    "dedupe:faqs": "tsx src/scripts/dedupeFaqs.ts",
    "bot:register:global": "tsx src/scripts/registerDiscordCommands.ts global",
    "bot:register:guild": "tsx src/scripts/registerDiscordCommands.ts guild",
    "cleanup:seed": "tsx src/scripts/cleanupSeedData.ts",
    "setup:new-cluster": "tsx src/scripts/setupNewCluster.ts",
    "test:hf-key": "tsx src/scripts/testHuggingFaceKey.ts",
    "recompute:tier": "tsx src/scripts/recomputeTier.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@sentry/node": "^10.55.0",
    "@shamagama/types": "workspace:*",
    "@shamagama/utils": "workspace:*",
    "@shamagama/validation": "workspace:*",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "discord-api-types": "^0.38.48",
    "discord.js": "^14.26.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.5.0",
    "markitdown-ts": "^0.0.10",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "obscenity": "^0.4.6",
    "openai": "^6.39.0",
    "rate-limit-redis": "^4.3.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/range-parser": "^1.2.7",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0"
  }
}
